# OpenAI — used only by transcribe.py (server-side pipeline), never shipped to the client.
OPENAI_API_KEY=

# Supabase — cross-device sync. The app works fully WITHOUT these (anonymous,
# localStorage-only); they only enable optional "sign in to sync".
# Both are public (anon key is safe to expose); find them in
# Supabase dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role — SERVER/CLI ONLY, never NEXT_PUBLIC_, never in the
# browser. It bypasses every RLS policy in the database. Used by the discovery
# harvest (scripts/harvest-youtube.mts) to write loro_video_candidates, which
# has RLS on with no policies and is unreachable any other way.
# Supabase dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# YouTube Data API v3 key, for the discovery harvest. Metadata only — the
# pipeline never downloads video. Google Cloud console → APIs & Services →
# Credentials, with "YouTube Data API v3" enabled on the project.
# Default quota is 10,000 units/day; one search.list costs 100.
YOUTUBE_API_KEY=
